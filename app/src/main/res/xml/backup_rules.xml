<?xml version="1.0" encoding="utf-8"?>
<!--
    No cloud backup for DVR — evidence integrity requires local-only storage.
    Sessions must be exported explicitly via the Evidence Packager.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database"   path="." />
    <exclude domain="file"       path="." />
</full-backup-content>

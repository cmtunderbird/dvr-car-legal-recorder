<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_main.xml — Main DVR screen (landscape).
  Layout: rear preview (left 72%) + control panel (right 28%)
  HudOverlayView sits on top of the rear preview — transparent, display only.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dvr_bg">

    <!-- Rear camera preview (left 72%) — CameraX PreviewView -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewRear"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/rightPanel"
        app:layout_constraintWidth_percent="0.72"
        app:scaleType="fillCenter" />

    <!-- HUD overlay — transparent, drawn on top of rear preview — NEVER modifies recording -->
    <com.dashcam.dvr.ui.hud.HudOverlayView
        android:id="@+id/hudOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="@id/previewRear"
        app:layout_constraintBottom_toBottomOf="@id/previewRear"
        app:layout_constraintStart_toStartOf="@id/previewRear"
        app:layout_constraintEnd_toEndOf="@id/previewRear" />

    <TextView
        android:id="@+id/labelRear"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ROAD"
        android:textColor="@color/white"
        android:textSize="9sp"
        android:fontFamily="monospace"
        android:background="#80000000"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        app:layout_constraintTop_toTopOf="@id/previewRear"
        app:layout_constraintStart_toStartOf="@id/previewRear"
        android:layout_marginStart="6dp"
        android:layout_marginTop="6dp" />

    <!-- Right panel (28%) — vertical stack of controls -->
    <LinearLayout
        android:id="@+id/rightPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="@color/dvr_blue_dark"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.28">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CABIN"
            android:textColor="@color/text_secondary"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:paddingBottom="2dp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextureView
                android:id="@+id/previewFront"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintDimensionRatio="H,16:9"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tvCameraStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Initialising cameras\u2026"
            android:textColor="@color/text_secondary"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:paddingVertical="3dp" />

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="00:00:00"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:paddingVertical="4dp" />

        <TextView
            android:id="@+id/tvGpsStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GPS Acquiring\u2026"
            android:textColor="@color/dvr_amber"
            android:textSize="9sp"
            android:gravity="center"
            android:paddingBottom="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRecord"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/start_recording"
            android:textSize="12sp"
            app:backgroundTint="@color/dvr_teal"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEvent"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="@string/save_event"
            android:textSize="11sp"
            app:backgroundTint="@color/dvr_red"
            android:enabled="false"
            android:layout_marginBottom="4dp" />

        <!-- Review protected events / settings -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReviewEvents"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="Review Events"
            android:textSize="10sp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="@color/dvr_teal"
            android:textColor="@color/dvr_teal"
            android:layout_marginBottom="4dp" />

        <!-- Protected events counter badge -->
        <TextView
            android:id="@+id/tvProtectedBadge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/dvr_amber"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:visibility="gone"
            android:text="" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
